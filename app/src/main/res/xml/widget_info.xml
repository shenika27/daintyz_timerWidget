<?xml version="1.0" encoding="utf-8"?>
<!--
  AppWidgetProviderInfo
  TODO(1차 구현): 2x3 셀 고정 크기에 맞춰 minWidth/minHeight, resizeMode 등 확정
  - initialLayout은 layoutMode(top/bottom) 기본값인 widget_timer_top 사용
  - resizeMode="none" (1차 버전은 리사이즈 미지원, 설계 문서 7장 제외 항목)
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:initialLayout="@layout/widget_timer_top"
    android:minWidth="110dp"
    android:minHeight="180dp"
    android:resizeMode="none"
    android:updatePeriodMillis="0"
    android:widgetCategory="home_screen"
    android:description="@string/widget_description" />
