<?xml version="1.0" encoding="utf-8"?>
<!--
  타이머 영역: "기능=영역, 버튼=그림" 구조 (사용자 결정).
   - 박스 배경(timer_box)/가로 구분선(div_h)/세로 구분선(div_*)/버튼 그림은 스킨이 그린다.
   - 버튼은 ImageView(클릭 영역)이며, 디폴트는 ic_btn_* 벡터, 노스킨은 그림만 투명(영역은 유지).
  버튼 자식 순서 = [minus][start_pause][plus][stop]. top/bottom 공통 include 라 id 통일 (설계 문서 2-1).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="2dp">

    <!-- 박스 배경 레이어: 스킨이 그린 디자인 PNG가 들어가는 자리(없으면 투명).
         내장 박스 모양(showBox)은 아래 timer_box의 background로 그린다. -->
    <ImageView
        android:id="@+id/iv_timer_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="fitXY" />

    <LinearLayout
        android:id="@+id/timer_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/timer_box_bg"
        android:orientation="vertical"
        android:padding="0dp">

    <!-- 디지털 시간 표시 (좌우 여백은 박스가 아닌 숫자에만 줘서 가로 구분선이 박스 끝까지 닿게) -->
    <TextView
        android:id="@+id/tv_timer_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:gravity="center"
        android:includeFontPadding="false"
        android:paddingHorizontal="8dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="@string/default_timer_value"
        android:textColor="@color/timer_digit"
        android:textSize="30sp"
        android:textStyle="bold" />

    <!-- 숫자/버튼 구분 가로선: 좌우 마진 없이 박스 양끝에 붙는다. 색/이미지는 코드에서 설정. -->
    <ImageView
        android:id="@+id/div_h"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:contentDescription="@null"
        android:scaleType="fitXY" />

    <!-- 버튼 행 -->
    <LinearLayout
        android:id="@+id/btn_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_minus"
            style="@style/WidgetTimerButton"
            android:contentDescription="@string/cd_minus"
            android:src="@drawable/ic_btn_minus" />

        <!-- minus와 함께 표시/숨김 -->
        <ImageView
            android:id="@+id/div_minus"
            style="@style/WidgetButtonDivider"
            android:contentDescription="@null"
            android:scaleType="fitXY" />

        <ImageView
            android:id="@+id/btn_start_pause"
            style="@style/WidgetTimerButton"
            android:contentDescription="@string/cd_start"
            android:src="@drawable/ic_btn_play" />

        <!-- plus와 함께 표시/숨김 -->
        <ImageView
            android:id="@+id/div_plus"
            style="@style/WidgetButtonDivider"
            android:contentDescription="@null"
            android:scaleType="fitXY" />

        <ImageView
            android:id="@+id/btn_plus"
            style="@style/WidgetTimerButton"
            android:contentDescription="@string/cd_plus"
            android:src="@drawable/ic_btn_plus" />

        <!-- stop와 함께 표시/숨김 -->
        <ImageView
            android:id="@+id/div_stop"
            style="@style/WidgetButtonDivider"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/btn_stop_reset"
            style="@style/WidgetTimerButton"
            android:contentDescription="@string/cd_stop"
            android:src="@drawable/ic_btn_stop"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 완료 상태 전용: 버튼 행 대신 "완료" 텍스트 하나로 통합. 탭하면 정지(IDLE) 복귀.
         평소엔 GONE, 완료 시 btn_row를 GONE으로 두고 이 뷰를 VISIBLE로 (WidgetUpdater). -->
    <TextView
        android:id="@+id/tv_complete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:includeFontPadding="false"
        android:paddingVertical="6dp"
        android:text="@string/timer_complete_label"
        android:textColor="@color/timer_digit"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
