<?xml version="1.0" encoding="utf-8"?>
<!--
  타이머 영역(가로 배치): 왼쪽 시간(~80%) + 오른쪽 버튼 2개 세로 컬럼(~20%).
   - 박스/세로선(시간↔버튼)/버튼사이 가로선은 모두 스킨의 timer_theme 배경(iv_timer_bg)에 그려진다.
     코드가 그리던 div_* 구분선은 제거됨 (모든 상태에서 선 구성이 동일해졌기 때문).
   - 버튼은 ImageView(클릭 영역)이며, 그림은 스킨 PNG(5종) 또는 내장 벡터, 노스킨은 투명(영역 유지).
   - 버튼 컬럼 자식(위→아래): [plus][minus][start_pause][stop]. 상태별로 2개만 VISIBLE(나머지 GONE 접힘).
       IDLE/COMPLETE → plus, minus / RUNNING·PAUSED → start_pause, stop.
   - 시간(tv_timer_value) 탭 = 시작/일시정지/재개(또는 완료 시 초기화). top/bottom 공통 include라 id 통일.
-->
<!-- 바깥 여백(가로 6dp/세로 비율)은 include 쪽(widget_timer_top/bottom)에서 지정한다. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 박스/선이 구워진 스킨 배경 PNG가 들어가는 자리(없으면 투명). 내장 박스(showBox)는 timer_box의 background. -->
    <ImageView
        android:id="@+id/iv_timer_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="fitXY" />

    <LinearLayout
        android:id="@+id/timer_box"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/timer_box_bg"
        android:orientation="horizontal"
        android:padding="0dp">

        <!-- 시간 표시(좌측 ~80%). 영역(time_area) 전체가 시작/일시정지 탭 타깃.
             내장 폰트 = tv_timer_value(TextView), 커스텀 폰트(.ttf) = iv_timer_value(비트맵). 코드가 둘 중 하나만 표시. -->
        <FrameLayout
            android:id="@+id/time_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4">

            <TextView
                android:id="@+id/tv_timer_value"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="monospace"
                android:gravity="center"
                android:includeFontPadding="false"
                android:paddingHorizontal="8dp"
                android:text="@string/default_timer_value"
                android:textColor="@color/timer_digit"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- 커스텀 폰트 숫자 비트맵 자리. fitCenter로 영역에 맞춰 축소. 평소 GONE. -->
            <ImageView
                android:id="@+id/iv_timer_value"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:scaleType="fitCenter"
                android:visibility="gone" />

        </FrameLayout>

        <!-- 버튼 세로 컬럼(우측 ~20%). 항상 2개만 보이며 컬럼 높이를 균등 2분할. -->
        <LinearLayout
            android:id="@+id/btn_row"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btn_plus"
                style="@style/WidgetTimerButton"
                android:contentDescription="@string/cd_plus"
                android:src="@drawable/ic_btn_plus" />

            <ImageView
                android:id="@+id/btn_minus"
                style="@style/WidgetTimerButton"
                android:contentDescription="@string/cd_minus"
                android:src="@drawable/ic_btn_minus" />

            <ImageView
                android:id="@+id/btn_start_pause"
                style="@style/WidgetTimerButton"
                android:contentDescription="@string/cd_start"
                android:src="@drawable/ic_btn_play"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_stop_reset"
                style="@style/WidgetTimerButton"
                android:contentDescription="@string/cd_stop"
                android:src="@drawable/ic_btn_stop"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
