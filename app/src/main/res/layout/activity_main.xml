<?xml version="1.0" encoding="utf-8"?>
<!--
  앱 메인 화면: 증감 단위 자유 설정(숫자패드), 타이머 상태 동기화 표시,
  타이머 위/아래 배치 전환 토글, 스킨 선택 화면 진입점 (설계 문서 3-2, 2-1).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/main_title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- 상태 동기화 표시 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_state"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_remaining"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- 증감 단위 설정 (숫자패드) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_step"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_step"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_step"
                android:importantForAutofill="no"
                android:inputType="number" />

            <Button
                android:id="@+id/btn_save_step"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_save_step" />
        </LinearLayout>

        <!-- 타이머 위/아래 배치 전환 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_layout_mode"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rg_layout_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rb_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/layout_top" />

            <RadioButton
                android:id="@+id/rb_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/layout_bottom" />
        </RadioGroup>

        <Button
            android:id="@+id/btn_open_skins"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_open_skins" />

        <Button
            android:id="@+id/btn_open_store"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_open_store" />

    </LinearLayout>
</ScrollView>
