<?xml version="1.0" encoding="utf-8"?>
<!--
  적용 미리보기: 상태 탭(정지/진행/일시정지/완료)으로 실제 위젯을 라이브 렌더한다.
  미리보는 영역만 해당 테마로 치환하고 나머지 영역은 현재 적용중 설정을 유지한다.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 상태 탭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_st_idle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/preview_state_idle" />

        <Button
            android:id="@+id/btn_st_run"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/preview_state_run" />

        <Button
            android:id="@+id/btn_st_paused"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/preview_state_paused" />

        <Button
            android:id="@+id/btn_st_complete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/preview_state_complete" />
    </LinearLayout>

    <!-- 위젯 라이브 렌더 컨테이너 -->
    <FrameLayout
        android:id="@+id/preview_container"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@drawable/widget_button_bg" />
</LinearLayout>
