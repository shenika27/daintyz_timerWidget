<?xml version="1.0" encoding="utf-8"?>
<!--
  창고 캐러셀 카드 1장 = 테마 1개.
  카드를 4:5 세로비로 고정해 기기 높이와 무관하게 일정한 크기로 가운데 배치한다(기존엔 페이지
  높이를 그대로 채워 카드가 너무 크고 휑했음). 위/아래 남는 공간은 캐러셀 여백이 된다.
  좌상단=즐겨찾기 별, 우상단=적용됨/가격 배지. 미보유면 딤 + 자물쇠.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_vault"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="10dp"
        app:cardBackgroundColor="@color/widget_background"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:strokeColor="@color/vault_card_stroke"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/iv_card_character"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:contentDescription="@string/cd_vault_card"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:src="@drawable/frame_placeholder" />

        <!-- 미보유 딤 (카드가 둥근 모서리로 클립) -->
        <View
            android:id="@+id/v_lock_dim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3403A33"
            android:visibility="gone" />

        <!-- 미보유 자물쇠 -->
        <ImageView
            android:id="@+id/iv_lock"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_locked"
            android:src="@drawable/ic_lock"
            android:visibility="gone" />
    </com.google.android.material.card.MaterialCardView>

    <!-- 적용됨 배지 (보유·적용중) -->
    <TextView
        android:id="@+id/tv_card_applied"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:elevation="6dp"
        android:background="@drawable/vault_badge_bg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="@string/vault_applied"
        android:textColor="@color/on_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/card_vault"
        app:layout_constraintEnd_toEndOf="@id/card_vault" />

    <!-- 가격 칩 (미보유) -->
    <TextView
        android:id="@+id/tv_card_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:elevation="6dp"
        android:background="@drawable/vault_price_bg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:textColor="@color/widget_text_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/card_vault"
        app:layout_constraintEnd_toEndOf="@id/card_vault" />

    <!-- 즐겨찾기 별 토글 (좌상단) -->
    <ImageView
        android:id="@+id/iv_card_star"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        android:elevation="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="@string/cd_favorite"
        android:focusable="true"
        android:padding="5dp"
        android:src="@drawable/ic_star_outline"
        app:layout_constraintTop_toTopOf="@id/card_vault"
        app:layout_constraintStart_toStartOf="@id/card_vault" />

</androidx.constraintlayout.widget.ConstraintLayout>
