<?xml version="1.0" encoding="utf-8"?>
<!--
  보유(테마) 화면: 가로 커버플로우 캐러셀.
  상단=필터 토글(구매한 항목만 / 즐겨찾기, 둘 다 기본 off=전체). 카드 하단=위치(1/9).
  보유=컬러/포커스 애니, 미보유=딤+자물쇠.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vault_bg">

    <!-- 필터 토글: [💰 구매한 항목] [★ 즐겨찾기] — 아이콘 전용 토글(독립, selected=켜짐) -->
    <LinearLayout
        android:id="@+id/filter_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/chip_owned"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:background="@drawable/vault_filter_toggle_bg"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/vault_owned_only"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_money"
            app:tint="@color/vault_filter_tint" />

        <ImageView
            android:id="@+id/chip_fav"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/vault_filter_toggle_bg"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/vault_favorites"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_star_outline"
            app:tint="@color/vault_filter_tint" />
    </LinearLayout>

    <!-- 포커스 테마 이름 (사실상 페이지 타이틀 역할) -->
    <TextView
        android:id="@+id/tv_theme_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="@color/on_surface"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/filter_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="우주 토끼" />

    <!-- 커버플로우 캐러셀: 높이를 비율로 고정해(폭 기준 10:9) 카드 바로 밑에 위치/버튼이 붙도록 한다 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_carousel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintDimensionRatio="10:9"
        app:layout_constraintTop_toBottomOf="@id/tv_theme_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 위치 (카드 바로 하단, 점 인디케이터 대체) -->
    <TextView
        android:id="@+id/tv_position"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/placeholder_fg"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/vp_carousel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="3 / 9" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:text="@string/vault_apply"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_preview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_preview"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="32dp"
        android:text="@string/vault_preview"
        android:textColor="@color/placeholder_fg"
        android:textSize="15sp"
        app:icon="@drawable/ic_search"
        app:iconGravity="textStart"
        app:iconPadding="6dp"
        app:iconSize="18dp"
        app:iconTint="@color/placeholder_fg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 빈 상태 (캐러셀 영역만 대체, 필터 행은 유지) -->
    <TextView
        android:id="@+id/tv_vault_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:textColor="@color/placeholder_fg"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filter_row"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="아직 즐겨찾기한 테마가 없어요." />

</androidx.constraintlayout.widget.ConstraintLayout>
